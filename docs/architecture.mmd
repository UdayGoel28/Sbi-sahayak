    classDef agt  fill:#3A3A88,color:#fff,stroke:#1A1A4B
    classDef hot  fill:#FF8A3D,color:#1A1A4B,stroke:#1A1A4B,font-weight:bold
    classDef dom  fill:#2E2E7A,color:#fff,stroke:#1A1A4B
    classDef gov  fill:#FF8A3D,color:#1A1A4B,stroke:#1A1A4B
    classDef data fill:#00B3A4,color:#1A1A4B,stroke:#1A1A4B
