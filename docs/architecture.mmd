flowchart TD
    subgraph CH["📱 CHANNELS"]
        WA["WhatsApp Cloud API"]:::ch
        VO["Voice · Bhashini (12+ languages)"]:::ch
        WEB["Web UI"]:::ch
        BM["Bank Mitra Kiosk (assisted mode)"]:::ch
    end

    subgraph OR["⚙️ ORCHESTRATOR · AGENT FABRIC"]
        RT["Intent router · LangGraph state machine · n8n workflows · memory"]:::orc
    end

    subgraph CA["🤖 CUSTOMER AGENTS"]
        SW["Swagat — acquire"]:::agt
        GU["Guru — adopt"]:::agt
        DI["Disha — engage ★"]:::hot
        RK["Rakshak — protect + include"]:::hot
    end

    subgraph DOM["🧠 DOMAIN LOGIC"]
        LK["Lakshya Engine\nauto-savings + gamification"]:::dom
        BS["Bill Sense\nshortfall prediction"]:::dom
        YF["Yojana Finder\nscheme eligibility + enrollment"]:::dom
        CP["Credit Passport\nalternative-data scoring"]:::dom
        RAG["Product RAG\nSBI docs + scheme rules"]:::dom
    end

    subgraph GV["🛡️ GOVERNANCE LAYER"]
        JG["Judge Agent\n(independent model)"]:::gov
        PC["Policy-as-Code\nRBI · UDAAP · KYC rules"]:::gov
        AT["Autonomy Tiers\nT1 auto · T2 confirm · T3 human"]:::gov
        AL["Immutable Audit Log\n+ Kill Switch"]:::gov
    end

    subgraph DL["🗄️ DATA LAYER"]
        FLG["Financial Life Graph\nPostgreSQL · per-customer state"]:::data
        VEC["RAG Corpus\npgvector · SBI docs · scheme rules"]:::data
        SYN["Synthetic Dataset\n1,000 users × 12 months UPI history"]:::data
        OBS["Langfuse Observability\nlive agent traces in demo"]:::data
    end

    CH --> OR
    OR --> CA
    CA --> DOM
    DI -- "proposes action" --> GV
    RK -- "proposes action" --> GV
    GV -- "T1 approved\nauto-deliver" --> CH
    GV -- "T2 approved\nawait customer confirm" --> CH
    GV -- "T3 approved\nawait human approval" --> CH
    GV -- "BLOCKED + reason\nlogged to audit" --> AL
    DOM --> DL
    CA --> DL
    GV --> DL

    classDef ch   fill:#2E2E7A,color:#fff,stroke:#1A1A4B
